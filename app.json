{
  "expo": {
    "name": "Zazi iZandi",
    "slug": "zazi-izandi-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "zz-app",
    "icon": "./assets/zazi-izandi-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.masinyusane.zz",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Zazi iZandi needs your location to verify you are at the school when signing in and out for time tracking.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/zazi-izandi-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "org.masinyusane.zz",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Zazi iZandi needs your location to verify you are at the school when signing in and out for time tracking."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "supabaseUrl": "REPLACE_WITH_ZZ_SUPABASE_URL",
      "supabaseAnonKey": "REPLACE_WITH_ZZ_SUPABASE_ANON_KEY",
      "eas": {
        "projectId": "REPLACE_WITH_ZZ_EAS_PROJECT_ID"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "REPLACE_WITH_ZZ_EAS_UPDATES_URL"
    },
    "owner": "jimmckeown"
  }
}
